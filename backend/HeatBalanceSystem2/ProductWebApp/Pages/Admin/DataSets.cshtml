@page
@model ProductWebApp.Pages.Admin.DataSetsModel
@{
    ViewData["Title"] = "Администрирование — наборы данных";
}

<h1 class="h4 mb-3">Администрирование — наборы исходных данных</h1>

<div class="table-responsive">
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>Пользователь</th>
                <th>Название</th>
                <th>Тип</th>
                <th>Обновлено</th>
                <th class="text-end">Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var ds in Model.DataSets)
            {
                <tr>
                    <td>@(ds.Owner?.Email ?? ds.OwnerId)</td>
                    <td>@ds.Name</td>
                    <td>@ds.CalculationType.ToDisplayName()</td>
                    <td>@ds.UpdatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                    <td class="text-end">
                        <form method="post" asp-page-handler="Delete" class="d-inline" onsubmit="return confirm('Удалить набор данных?');">
                            <input type="hidden" name="id" value="@ds.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-danger">Удалить</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

