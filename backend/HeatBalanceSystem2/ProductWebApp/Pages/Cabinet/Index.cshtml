@page
@model ProductWebApp.Pages.Cabinet.IndexModel
@{
    ViewData["Title"] = "Личный кабинет";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h4 mb-0">Личный кабинет</h1>
    <a class="btn btn-primary" href="/Cabinet/Create">Создать набор данных</a>
</div>

@if (Model.DataSets.Count == 0)
{
    <div class="alert alert-info">
        Наборов исходных данных пока нет. Нажмите <strong>«Создать набор данных»</strong>.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th>Название</th>
                    <th>Тип расчёта</th>
                    <th>Обновлено</th>
                    <th class="text-end">Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var ds in Model.DataSets)
                {
                    <tr>
                        <td>
                            <div class="fw-semibold">
                                <a class="text-decoration-none" href="/Cabinet/DataSetDetails?id=@ds.Id">@ds.Name</a>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(ds.Comment))
                            {
                                <div class="text-muted small">@ds.Comment</div>
                            }
                        </td>
                        <td>@ds.CalculationType.ToDisplayName()</td>
                        <td>@ds.UpdatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-secondary" href="/Cabinet/Edit?id=@ds.Id">Редактировать</a>
                            <form method="post" asp-page-handler="Run" class="d-inline">
                                <input type="hidden" name="id" value="@ds.Id" />
                                <button type="submit" class="btn btn-sm btn-success">Рассчитать</button>
                            </form>
                            <form method="post" asp-page-handler="Delete" class="d-inline" onsubmit="return confirm('Удалить набор данных?');">
                                <input type="hidden" name="id" value="@ds.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">Удалить</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

